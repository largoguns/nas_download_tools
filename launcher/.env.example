# El launcher lee la lista de apps (nombre, url, icono, descripcion, color) desde
# config.json. Edita ese fichero para cambiar los botones.

# Ruta del config.json dentro del contenedor. Por defecto usa el incluido en la
# imagen. Para editarlo sin reconstruir, monta el tuyo (ver docker-compose.yml)
# y, si lo pones en otra ruta, indicalo aqui.
# CONFIG_PATH=/app/config.json
