SPOTUBE_WEB_PORT=8080
# En WSL/Windows, una ruta bajo /mnt/c o /mnt/d puede ser bastante mas lenta
# desde Docker. Para pruebas de velocidad usa una ruta Linux o el disco USB real.
MUSIC_HOST_DIR=./music
SPOTDL_COOKIE_HOST_DIR=./cookies_store
SPOTDL_AUDIO_PROVIDERS=youtube-music,youtube
SPOTDL_THREADS=1
SPOTDL_LOG_LEVEL=INFO
SPOTDL_LOG_TRACEBACKS=false
SPOTDL_REPROCESS_MISSING_ONLY=false
SPOTDL_MAX_ATTEMPTS=5
SPOTDL_RETRY_DELAY_SECONDS=120
SPOTDL_RETRY_BACKOFF_FACTOR=2
SPOTDL_RETRY_MAX_DELAY_SECONDS=900
SPOTDL_RETRY_ALL_FAILURES=true
SPOTDL_SPOTIFY_MAX_RETRIES=5
SPOTDL_SAVE_TIMEOUT_SECONDS=60
# Exporta cookies de YouTube en formato Netscape a ./cookies_store/youtube.txt si YouTube pide login.
# SPOTDL_COOKIE_FILE=/cookies/youtube.txt
SPOTDL_YT_DLP_ARGS=
METADATA_WORKER_SLEEP_SECONDS=10
SPOTIFY_METADATA_TIMEOUT=8

# La pantalla "Busqueda" usa la API publica de Deezer (sin credenciales ni
# configuracion). No hay nada que rellenar aqui.

# Escaneo de biblioteca de Navidrome al completar descargas (opcional).
# Si dejas cualquiera de las tres vacia, no se hace nada.
NAVIDROME_URL=
NAVIDROME_USER=
NAVIDROME_PASSWORD=
# Escaneo unico tras N segundos sin nuevas descargas (agrupa lotes).
NAVIDROME_SCAN_DEBOUNCE_SECONDS=30
