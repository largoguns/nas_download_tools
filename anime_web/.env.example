ANIME_WEB_PORT=8090
ANIME_DATA_DIR=./data
ANIME_DOWNLOAD_DIR=./downloads
LOG_LEVEL=INFO
FFMPEG_BIN=ffmpeg
PREFERRED_QUALITY=360p
# Numero de descargas simultaneas (1 = secuencial, por defecto).
DOWNLOAD_CONCURRENCY=1
# Reintentos al reanudar una descarga ya iniciada / cuando el servidor no responde aun.
DOWNLOAD_MAX_RETRIES=5
DOWNLOAD_START_RETRIES=1
# Orden de servidores a probar (coma). Vacio = orden por defecto (mediafire primero).
ANIME_DOWNLOAD_SERVER_PRIORITY=
# Reintentos de peticiones HTML ante cortes de conexion (todas las fuentes).
ANIME_HTML_RETRIES=2
ANIME_HTML_RETRY_BACKOFF=1.0
ANIME_JKANIME_MAX_EPISODE_PAGES=100
ANIME_JKANIME_EPISODE_PAUSE_SECONDS=0.25
# Descarga directa via el CDN de jkanime (c1.jkplayers.com/d/{slug}/) en vez de
# resolver cada host con extractores. Los extractores quedan como fallback.
ANIME_JKANIME_DIRECT_DOWNLOAD=true
ANIME_JKANIME_EXTRACTOR_FALLBACK=true
# Reintentos al cargar la pagina del episodio (jkanime corta conexiones a veces).
ANIME_JKANIME_PAGE_RETRIES=2
ANIME_JKANIME_PAGE_RETRY_BACKOFF=1.0

# Optional demo source. Disabled by default because Jkanime is the active source.
ANIME_ENABLE_DEMO=false
ANIME_DEMO_MEDIA_URL=

# Refresco de biblioteca de Jellyfin al completar descargas (opcional).
# Si dejas JELLYFIN_URL o JELLYFIN_API_KEY vacios, no se hace nada.
JELLYFIN_URL=
JELLYFIN_API_KEY=
# ItemId de la biblioteca a escanear (p. ej. Anime). Vacio = todas.
# Para verlos: curl "$JELLYFIN_URL/Library/VirtualFolders?api_key=$JELLYFIN_API_KEY"
JELLYFIN_LIBRARY_ID=
# Escaneo unico tras N segundos sin nuevas descargas (agrupa lotes).
JELLYFIN_REFRESH_DEBOUNCE_SECONDS=30
