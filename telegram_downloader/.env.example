TELEGRAM_WEB_PORT=8100
TELEGRAM_DOWNLOAD_DIR=./downloads
LOG_LEVEL=INFO

# Credenciales MTProto. Obtenlas en https://my.telegram.org -> API development tools.
TG_API_ID=
TG_API_HASH=
# Cadena de sesion de usuario. Generala una vez con: python login.py
# Da acceso completo a tu cuenta: mantenla en privado y fuera de git.
TG_SESSION_STRING=

# Numero de mensajes recientes a mostrar en la consola del bot.
BOT_HISTORY_LIMIT=15
# Cadencia del worker secuencial cuando la cola esta vacia (segundos).
WORKER_SLEEP_SECONDS=3
# Cada cuantos segundos se persiste el progreso de bytes durante una descarga.
PROGRESS_UPDATE_SECONDS=1

# Refresco de biblioteca de Jellyfin al completar descargas (opcional).
# Si dejas JELLYFIN_URL o JELLYFIN_API_KEY vacios, no se hace nada.
JELLYFIN_URL=
JELLYFIN_API_KEY=
# ItemId de la biblioteca a escanear (p. ej. Peliculas). Vacio = todas.
# Para verlos: curl "$JELLYFIN_URL/Library/VirtualFolders?api_key=$JELLYFIN_API_KEY"
JELLYFIN_LIBRARY_ID=
# Escaneo unico tras N segundos sin nuevas descargas (agrupa lotes).
JELLYFIN_REFRESH_DEBOUNCE_SECONDS=30
